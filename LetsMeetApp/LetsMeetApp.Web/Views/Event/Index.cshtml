@model EventIndexViewModel

@{
    ViewData["Title"] = "Events Dashboard";
}

<h2>My Events</h2>

@if (!Model.MyEvents.Any())
{
    <p>You are not participating in any events yet.</p>
}
else
{
    <ul>
        <div class="row justify-content-center">
            @foreach (var ev in Model.MyEvents)
            {
                <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
                    <div class="card h-100 w-100 shadow-sm">

                        <img src="@(string.IsNullOrEmpty(ev.ImageUrl)
                            ? Url.Content("~/images/no-image.png")
                            : ev.ImageUrl)"
                             class="card-img-top img-fluid rounded"
                             alt="@ev.Title"
                             style="height:300px; object-fit:cover;" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">@ev.Title</h5>

                            <p class="card-text flex-grow-1">
                                @(ev.Description.Length > 100
                                    ? ev.Description.Substring(0, 100) + "..."
                                    : ev.Description)
                            </p>

                            <p class="card-text">
                                <small class="text-muted">
                                    @ev.Date.ToString("dd MMM yyyy HH:mm")
                                </small><br />
                                <small class="text-muted">
                                    @ev.City, @ev.Country
                                </small><br />
                                <small class="text-muted">
                                    Category: @ev.CategoryName
                                </small><br />
                                <small class="text-muted">
                                    By: @ev.CreatorFullName
                                </small>
                            </p>

                            <div class="mt-auto d-flex gap-2">

                                <a asp-controller="Event"
                                   asp-action="Details"
                                   asp-route-id="@ev.Id"
                                   class="btn btn-primary flex-fill">
                                    View
                                </a>

                                @if (ev.IsCreator)
                                {
                                    <a asp-controller="Event"
                                       asp-action="Edit"
                                       asp-route-id="@ev.Id"
                                       class="btn btn-warning flex-fill">
                                        Edit
                                    </a>

                                    <a asp-controller="Event"
                                       asp-action="Delete"
                                       asp-route-id="@ev.Id"
                                       class="btn btn-danger flex-fill">
                                        Delete
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-warning flex-fill" disabled>
                                        Edit
                                    </button>

                                    <button class="btn btn-danger flex-fill" disabled>
                                        Delete
                                    </button>
                                }

                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    </ul>
}

<hr />

<h2>Discover Events</h2>

<form method="get">
    <label>
        <input type="checkbox"
               name="EventsNearMe"
               value="true"
        @(Model.Filter.EventsNearMe ? "checked" : "") />
        Events Near Me
    </label>

    <button type="submit">Apply Filter</button>
</form>

<br />

@if (!Model.DiscoverEvents.Any())
{
    <p>No events found.</p>
}
else
{
    <ul>
        @foreach (var ev in Model.DiscoverEvents)
        {
            <li>
                <strong>@ev.Title</strong> <br />
                City: @ev.City <br />
                Date: @ev.Date.ToString("dd MMM yyyy")
            </li>
        }
    </ul>
}