@model EventIndexViewModel

@{
    ViewData["Title"] = "Events Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-3">

    <a asp-controller="Event"
       asp-action="PastEvents"
       class="btn btn-secondary">
        View Past Events
    </a>

    <div class="flex-grow-1 d-flex justify-content-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger text-center py-2 px-4 mb-0">
                @TempData["ErrorMessage"]
            </div>
        }
        else if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center py-2 px-4 mb-0">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>

</div>

<h2 class="text-center fw-bold mb-4">Events I'm Attending</h2>

@if (!Model.MyEvents.Any())
{
    <div class="row justify-content-center">
        <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
            <a asp-controller="Event"
               asp-action="Create"
               class="card h-100 w-100 shadow-sm text-decoration-none text-dark">

                <div class="card-body d-flex flex-column justify-content-center align-items-center">

                    <div class="display-1 fw-bold text-primary">
                        +
                    </div>

                    <h5 class="mt-3">Create Your Event</h5>

                </div>

            </a>
        </div>
    </div>
}
else
{
    <div class="row justify-content-center">
        @foreach (var ev in Model.MyEvents)
        {
            <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
                <div class="card h-100 w-100 shadow-sm">

                    <img src="@(string.IsNullOrEmpty(ev.ImageUrl)
                            ? Url.Content("~/images/no-image.png")
                            : ev.ImageUrl)"
                         class="card-img-top img-fluid rounded"
                         alt="@ev.Title"
                         style="height:300px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@ev.Title</h5>

                        <p class="card-text flex-grow-1">
                            @(ev.Description.Length > 100
                                ? ev.Description.Substring(0, 100) + "..."
                                : ev.Description)
                        </p>

                        <p class="card-text">
                            <small class="text-muted">
                                @ev.Date.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </small><br />
                            <small class="text-muted">
                                @ev.Location, @ev.City, @ev.Country
                            </small><br />
                            <small class="text-muted">
                                Category: @ev.CategoryName
                            </small><br />
                            <small class="text-muted">
                                Participants: @ev.ParticipantsCount
                            </small><br />
                            <small class="text-muted">
                                By: @ev.CreatorFullName
                            </small>
                        </p>

                        <div class="mt-auto d-flex gap-2">

                            <a asp-controller="Event"
                               asp-action="Details"
                               asp-route-id="@ev.Id"
                               class="btn btn-primary flex-fill">
                                View
                            </a>

                            @if (ev.IsCreator)
                            {
                                <a asp-controller="Event"
                                   asp-action="Edit"
                                   asp-route-id="@ev.Id"
                                   class="btn btn-warning flex-fill">
                                    Edit
                                </a>

                                <a asp-controller="Event"
                                   asp-action="Delete"
                                   asp-route-id="@ev.Id"
                                   class="btn btn-danger flex-fill">
                                    Delete
                                </a>
                            }
                            else
                            {
                                <form asp-controller="EventParticipation"
                                      asp-action="Leave"
                                      asp-route-id="@ev.Id"
                                      method="post"
                                      class="flex-fill">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger w-100">
                                        Leave
                                    </button>

                                </form>
                            }

                        </div>

                    </div>
                </div>
            </div>
        }

        <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
            <a asp-controller="Event"
               asp-action="Create"
               class="card h-100 w-100 shadow-sm text-decoration-none text-dark">

                <div class="card-body d-flex flex-column justify-content-center align-items-center">

                    <div class="display-1 fw-bold text-primary">
                        +
                    </div>

                    <h5 class="mt-3">Create New Event</h5>

                </div>

            </a>
        </div>
    </div>
}

<hr />

<h2 class="text-center fw-bold mb-4">Discover Events</h2>

<div class="d-flex justify-content-center my-3">
    <form method="get" class="d-flex align-items-center gap-3">
        <div class="form-check">
            <input class="form-check-input"
                   type="checkbox"
                   name="EventsNearMe"
                   value="true"
            @(Model.Filter.EventsNearMe ? "checked" : "") />

            <label class="form-check-label">
                Events In My City
            </label>
        </div>

        <button type="submit" class="btn btn-outline-primary">
            Apply Filter
        </button>
    </form>
</div>

@if (!Model.DiscoverEvents.Any())
{
    <p class="text-center">No events found.</p>
}
else
{
    <div class="row justify-content-center">
        @foreach (var ev in Model.DiscoverEvents)
        {
            <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
                <div class="card h-100 w-100 shadow-sm">

                    <img src="@(string.IsNullOrEmpty(ev.ImageUrl)
                            ? Url.Content("~/images/no-image.png")
                            : ev.ImageUrl)"
                         class="card-img-top img-fluid rounded"
                         alt="@ev.Title"
                         style="height:300px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@ev.Title</h5>

                        <p class="card-text flex-grow-1">
                            @(ev.Description.Length > 100
                                ? ev.Description.Substring(0, 100) + "..."
                                : ev.Description)
                        </p>

                        <p class="card-text">
                            <small class="text-muted">
                                @ev.Date.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </small><br />
                            <small class="text-muted">
                                @ev.Location, @ev.City, @ev.Country
                            </small><br />
                            <small class="text-muted">
                                Category: @ev.CategoryName
                            </small><br />
                            <small class="text-muted">
                                Participants: @ev.ParticipantsCount
                            </small><br />
                            <small class="text-muted">
                                By: @ev.CreatorFullName
                            </small>
                        </p>

                        <div class="mt-auto d-flex gap-2">

                            <a asp-controller="Event"
                               asp-action="Details"
                               asp-route-id="@ev.Id"
                               class="btn btn-primary flex-fill">
                                View
                            </a>

                            <form asp-controller="EventParticipation"
                                  asp-action="Join"
                                  asp-route-id="@ev.Id"
                                  method="post"
                                  class="flex-fill">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success w-100">
                                    Join Event
                                </button>

                            </form>

                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    <br />
}
