@model EventDetailsViewModel

<div class="container my-4">

    <div class="d-flex align-items-center justify-content-between mb-3">

        <a asp-action="Index" class="btn btn-secondary">
            ← Back to Events
        </a>

        <div class="flex-grow-1 d-flex justify-content-center">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success text-center py-2 px-4 mb-0">
                    @TempData["SuccessMessage"]
                </div>
            }
        </div>

    </div>

    <div class="card shadow-sm">

        <!-- Image Hero Section -->
        <div class="position-relative bg-light d-flex justify-content-center align-items-center"
             style="max-height:500px; overflow:hidden;">

            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/images/no-image.png") : Model.ImageUrl)"
                 class="img-fluid"
                 alt="@Model.Title"
                 style="max-height:500px; object-fit:contain;" />

            <!-- Title Overlay -->
            <div class="position-absolute bottom-0 start-0 w-100 text-white"
                 style="background:rgba(0,0,0,0.55);">

                <div class="p-3 text-center">
                    <h1 class="fw-bold mb-0">@Model.Title</h1>
                </div>

            </div>

        </div>

        <div class="card-body text-center">

            <p class="fs-5 mt-3">
                @Model.Description
            </p>

            <div class="mt-4 fs-5">

                <p class="mb-2">
                    <strong>Date:</strong> @Model.Date.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                </p>

                <p class="mb-2">
                    <strong>Location:</strong> @Model.Location, @Model.City, @Model.Country
                </p>

                <p class="mb-2">
                    <strong>Category:</strong> @Model.CategoryName
                </p>

                <p class="mb-2">
                    <strong>Participants:</strong> @Model.ParticipantsCount
                </p>

                <p class="mb-3">
                    <strong>Organizer:</strong> @Model.CreatorFullName
                </p>

            </div>

            @if (Model.Date > DateTime.UtcNow)
            {
                <div class="mt-4 d-flex justify-content-center gap-3">

                    @if (Model.IsCreator)
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning px-4">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-danger px-4">
                            Delete
                        </a>
                    }
                    else
                    {
                        @if (Model.HasJoined)
                        {
                            <form asp-controller="EventParticipation"
                                  asp-action="Leave"
                                  asp-route-id="@Model.Id"
                                  method="post"
                                  class="d-inline">

                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-danger px-4">
                                    Leave Event
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="EventParticipation"
                                  asp-action="Join"
                                  asp-route-id="@Model.Id"
                                  method="post"
                                  class="d-inline">

                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-success w-100">
                                    Join Event
                                </button>
                            </form>
                        }
                    }

                </div>
            }

        </div>

    </div>

</div>