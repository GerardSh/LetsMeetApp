@model IEnumerable<EventViewModel>

@{
    ViewData["Title"] = "Past Events";
}

<div class="container my-4">

    <a asp-action="Index" class="btn btn-secondary mb-3">
        ← Back to Events Dashboard
    </a>

    <h2 class="text-center fw-bold mb-4">Past Events</h2>

    <!-- Info alert -->
    <div class="alert alert-info text-center">
        Past events are read-only and cannot be modified.
    </div>

    @if (!Model.Any())
    {
        <p class="text-center text-muted">You have no past events.</p>
    }
    else
    {
        <div class="row justify-content-center">
            @foreach (var ev in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
                    <div class="card h-100 w-100 shadow-sm border-secondary">

                        <img src="@(string.IsNullOrEmpty(ev.ImageUrl)
                            ? Url.Content("~/images/no-image.png")
                            : ev.ImageUrl)"
                             class="card-img-top img-fluid rounded"
                             style="height:300px; object-fit:cover;" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">@ev.Title</h5>

                            <p class="card-text flex-grow-1">
                                @(ev.Description.Length > 100
                                    ? ev.Description.Substring(0, 100) + "..."
                                    : ev.Description)
                            </p>

                            <p class="card-text">
                                <small class="text-muted">
                                    @ev.Date.ToString("dd MMM yyyy HH:mm")
                                </small>
                            </p>

                            <a asp-controller="Event"
                               asp-action="Details"
                               asp-route-id="@ev.Id"
                               class="btn btn-primary flex-fill mt-auto">
                                View Details
                            </a>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>