@model IEnumerable<LetsMeetApp.Web.ViewModels.Event.EventViewModel>

@{
    ViewData["Title"] = "Welcome";
}

<div class="text-center my-3">
    <h1>Welcome to LetsMeetApp!</h1>
    <p class="lead">
        Create and join events, meet people, and connect with others in your city.
    </p>

    @if (Model.Any())
    {
        <p class="lead">Check out some upcoming events below.</p>
    }

</div>

<div class="row justify-content-center">
    @foreach (var ev in Model)
    {
        <div class="col-12 col-sm-6 col-lg-4 mb-3 d-flex">
            <div class="card h-100 w-100">
                <img src="@(string.IsNullOrEmpty(ev.ImageUrl)
                            ? Url.Content("~/images/no-image.png")
                            : ev.ImageUrl)"
                     class="card-img-top img-fluid rounded hover-zoom" alt="@ev.Title"
                     style="height:300px; object-fit:cover; object-position:center" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@ev.Title</h5>
                    <p class="card-text flex-grow-1">
                        @(ev.Description.Length > 100
                            ? ev.Description.Substring(0, 100) + "..."
                            : ev.Description)
                    </p>
                    <p class="card-text">
                        <small class="text-muted">@ev.Date.ToString("dd MMM yyyy HH:mm")</small><br />
                        <small class="text-muted">@ev.City, @ev.Country</small><br />
                        <small class="text-muted">Category: @ev.CategoryName</small><br />
                        <small class="text-muted">Participants: @ev.ParticipantsCount</small><br />
                        <small class="text-muted">By: @ev.CreatorFullName</small>
                    </p>
                </div>
            </div>
        </div>
    }
</div>

<div class="text-center my-3">
    <h3>Want to create or join events?</h3>
    <p class="lead">
        Register now and start connecting with people around you.
    </p>

    <div class="d-flex justify-content-center gap-3 mt-3">
        <a asp-area="Identity"
           asp-page="/Account/Register"
           class="btn btn-primary btn-lg">
            Register
        </a>

        <a asp-area="Identity"
           asp-page="/Account/Login"
           class="btn btn-outline-primary btn-lg">
            Login
        </a>
    </div>
</div>
